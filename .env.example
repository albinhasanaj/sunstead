# Copy to .env.local and fill in. Never commit .env.local (it's gitignored).

# ── Required ────────────────────────────────────────────────────────────────────

# Vercel AI Gateway — routes every agent LLM call AND the embeddings used by memory.
# Vercel dashboard → AI Gateway → API keys.
AI_GATEWAY_API_KEY=

# Supabase Postgres — long-term memory (pgvector) + game/user rows.
# Use the SESSION POOLER connection string (IPv4): Supabase dashboard → Connect →
# Session pooler. The direct host (db.<ref>.supabase.co) is IPv6-only and won't work
# on IPv4-only networks. Without this the game still runs, just memory-less.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ElevenLabs — voice (TTS/STT) and the music/SFX routes. elevenlabs.io → API keys.
ELEVENLABS_API_KEY=

# ── Optional ────────────────────────────────────────────────────────────────────

# Featherless — open-weight seats (DeepSeek, Kimi, GLM, Qwen, Llama, Mistral).
# Without it those seats fall back to the gateway model. featherless.ai → API keys.
FEATHERLESS_API_KEY=

# DB connection extras (rarely needed):
#   POSTGRES_URL / SUPABASE_DB_URL  — accepted as aliases for DATABASE_URL
#   PGSSLROOTCERT=/path/to/ca.pem   — CA cert for verify-full TLS (else TLS w/o verify)
#   PGSSL=disable                   — turn off TLS (e.g. a local Postgres)
#   PGPOOL_MAX=5                    — max pooled connections (default 5)

# Voice model overrides:
#   ELEVENLABS_MODEL=eleven_flash_v2_5
#   ELEVENLABS_STT_MODEL=scribe_v2

# Gameplay tuning (see code for full list and defaults), e.g.:
#   MAFIA_MODEL=                    — force every seat onto one gateway model
#   MAFIA_CONTEXT_WINDOW=15         — public-log lines shown in-prompt
#   MAFIA_TURN_TIMEOUT_MS=30000     — per-seat LLM hard cap
#   MAFIA_RECALL_TIMEOUT_MS=8000    — per-turn memory recall time-box
#   MAFIA_PARALLEL=1                — concurrent NIGHT/VOTE resolution (0 = sequential)
#   MAFIA_LIVE_URGE=0               — paid live hand-raise during discussion
