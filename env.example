ELEVENLABS_API_KEY=
AI_GATEWAY_API_KEY=
DATABASE_URL=
FEATHERLESS_API_KEY=

# ── Supabase Auth ──────────────────────────────────────────────────────────────
# Project API settings. For local dev these are printed by `supabase start`
# (API URL + anon key). NEXT_PUBLIC_* values are exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth for Supabase Auth (referenced by supabase/config.toml
# [auth.external.google]). Create a "Web application" OAuth client in Google Cloud →
# APIs & Services → Credentials, with the redirect URI:
#   http://127.0.0.1:54321/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=